{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@repo/shared":   ["../../packages/shared/src/index.ts"],
      "@repo/shared/*": ["../../packages/shared/src/*"],
      "@repo/db":       ["../../packages/db/src/index.ts"],
      "@repo/db/*":     ["../../packages/db/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}