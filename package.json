{
  "name": "ludo-king",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "bun run --filter @repo/server dev",
    "dev:client": "bun run --filter @repo/client dev",
    "db:generate": "bun run --filter @repo/db generate",
    "db:migrate": "bun run --filter @repo/db migrate",
    "db:studio": "bun run --filter @repo/db studio",
    "generate": "prisma generate --schema=prisma/schema.prisma",
    "migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "migrate:prod": "prisma migrate deploy --schema=prisma/schema.prisma",
    "studio": "prisma studio --schema=prisma/schema.prisma",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "bun": "^1.3.14",
    "hono": "^4.12.25"
  }
}